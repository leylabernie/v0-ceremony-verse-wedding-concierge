# Mailchimp Integration — used by /api/subscribe and /api/lead
# Used for: free guide downloads, exit popup, style quiz leads
MAILCHIMP_API_KEY=your-mailchimp-api-key
MAILCHIMP_SERVER=us4
MAILCHIMP_AUDIENCE_ID=your-audience-id

# Mailchimp Merge Fields (create these in your Mailchimp audience settings):
# FNAME — First Name (text)
# PHONE — Phone (phone)
# SOURCE — Lead Source (text): exit_popup, style_quiz, sticky_cta, free_guide
# STYLE — Quiz Style (text): traditional, modern, fusion, unsure
# TRAD — Quiz Tradition (text): gujarati, punjabi, south_indian, etc.
# BUDGET — Quiz Budget (text): under_1k, 1k_3k, 3k_5k, 5k_plus
# TLINE — Quiz Timeline (text): 3_6_months, 6_12_months, 12_plus, just_starting
